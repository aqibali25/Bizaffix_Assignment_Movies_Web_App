{
  "homepage": "https://aqibali25.github.io/Bizaffix_Assignment_Movies_Web_App",
  "name": "bizaffix_assignment_movies_web_app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --bun vite",
    "build": "bun run --bun vite build",
    "preview": "bun run --bun vite preview",
    "lint": "bun run --bun eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "clean": "rm -rf node_modules bun.lockb",
    "reinstall": "bun run clean && bun install",
    "db:setup": "bun run src/scripts/setupDb.js",
    "predeploy": "bun run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "framer-motion": "^10.16.16",
    "lodash": "^4.17.21",
    "lucide-react": "^0.575.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.1",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.8"
  },
  "bun": {
    "alwaysBundle": true
  }
}
